<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.ys.commens.dao.YsProductReviewDao">
    <resultMap type="org.ys.commens.entity.YsProductReview" id="YsProductReviewMap">
        <result property="id" column="id" jdbcType="BIGINT"/>
        <result property="orderId" column="order_id" jdbcType="BIGINT"/>
        <result property="goodsId" column="goods_id" jdbcType="BIGINT"/>
        <result property="userId" column="user_id" jdbcType="BIGINT"/>
        <result property="username" column="username" jdbcType="VARCHAR"/>
        <result property="rating" column="rating" jdbcType="TINYINT"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="images" column="images" jdbcType="VARCHAR"/>
        <result property="isAnonymous" column="is_anonymous" jdbcType="TINYINT"/>
        <result property="createdAt" column="created_at" jdbcType="TIMESTAMP"/>
        <result property="updatedAt" column="updated_at" jdbcType="TIMESTAMP"/>
        <result property="replyContent" column="reply_content" jdbcType="VARCHAR"/>
        <result property="replyTime" column="reply_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 根据商品ID查询评价列表（分页） -->
    <select id="queryReviewsByGoodsId" resultMap="YsProductReviewMap">
        select * from ys_tb.ys_product_review
        where goods_id = #{goodsId}
        order by created_at desc
    </select>

    <!-- 根据用户ID查询评价列表（分页） -->
    <select id="queryReviewsByUserId" resultMap="YsProductReviewMap">
        select * from ys_tb.ys_product_review
        where user_id = #{userId}
        order by created_at desc
    </select>

    <!-- 查询商品的平均评分 -->
    <select id="getGoodsRatingStats" resultType="java.util.HashMap">
        select
            count(*) as total_count,
            avg(rating) as avg_rating,
            sum(case when rating = 5 then 1 else 0 end) as five_star,
            sum(case when rating = 4 then 1 else 0 end) as four_star,
            sum(case when rating = 3 then 1 else 0 end) as three_star,
            sum(case when rating = 2 then 1 else 0 end) as two_star,
            sum(case when rating = 1 then 1 else 0 end) as one_star
        from ys_tb.ys_product_review
        where goods_id = #{goodsId}
    </select>

    <!-- 检查用户是否已评价过该订单商品 -->
    <select id="checkReviewed" resultMap="YsProductReviewMap">
        select * from ys_tb.ys_product_review
        where order_id = #{orderId}
        and user_id = #{userId}
        and goods_id = #{goodsId}
        limit 1
    </select>
    <!-- 根据商品ID分页查询评价（供 MyBatis-Plus 分页插件使用） -->
    <select id="selectByGoodsId" resultMap="YsProductReviewMap">
        select * from ys_tb.ys_product_review
        where goods_id = #{goodsId}
        order by created_at desc
    </select>
</mapper>
